# Postgres connection string used by the backend and the seed script.
# Copy to ".env" and adjust if your Postgres user/host/db differ.
#
# Default (works out of the box on a stock Homebrew Postgres where the DB role
# matches your OS user and needs no password):
#   DATABASE_URL=postgresql://<your-os-user>@localhost:5432/cos_scheduler
#
# With an explicit password:
#   DATABASE_URL=postgresql://user:password@localhost:5432/cos_scheduler

DATABASE_URL=postgresql://localhost:5432/cos_scheduler

# Optional — API port (defaults to 4100).
# PORT=4100

# ── AI mode (Claude) ─────────────────────────────────────────────────────────
# Powers the "AI" toggle in the chat. Leave blank to keep rule-only mode (the
# toggle still appears but AI replies explain it isn't configured). Get a key at
# https://console.anthropic.com → API Keys.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Microsoft Outlook (Microsoft Graph) integration ──────────────────────────
# Leave these blank to run in mock mode (no real calendar writes). Fill them in
# from your Entra ID app registration to mirror events to a real Outlook
# calendar and send invitations/updates/cancellations automatically.
#
# MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MS_CLIENT_SECRET=your-client-secret-value
# "consumers" = personal Microsoft accounts (outlook.com); "common" = personal + work/school.
# MS_TENANT=consumers
# Must EXACTLY match a Redirect URI registered on the app (Web platform).
# MS_REDIRECT_URI=http://localhost:4100/api/auth/callback
# Where the backend sends the browser back after sign-in.
# FRONTEND_URL=http://localhost:5173
